# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Virtualenv (uv managed at workspace root)
.venv/

# IDE
.idea/
.vscode/

# EPA / chemtreat_water_leads run artifacts (regenerable from the pipeline)
EPA/snapshot.sqlite
EPA/out/
EPA/cache/

# dump_run output — pure cache of snapshot.sqlite, rebuildable any time via
# `python -m chemtreat_water_leads.dump_run --latest`
EPA/materialized/

# Viewer screenshots — kept locally for reference, not source-controlled
EPA/chemtreat_water_leads_viewer/images/Screenshot*.png

# Bulk-loader cache (large ECHO ZIPs)
**/echo_exporter.zip
**/npdes_downloads.zip
**/SDWA_latest_downloads.zip

# Briefings state — operational, not source of truth
EPA/briefings_state.sqlite

# Briefings run outputs — generated per region per run. Reference
# examples (the seed of "what a briefing looks like") live under
# chemtreat_sales_briefings/samples/ and ARE tracked.
EPA/chemtreat_sales_briefings/out/

# Secrets — never commit. .env.example is fine to track.
.env
**/.env
