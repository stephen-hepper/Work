# Copy this file to EPA/.env and fill in the values you need. The
# briefings script reads .env at startup; shell-exported env vars
# always take precedence so you can override on a per-shell basis.
#
# Add EPA/.env to your .gitignore — it will contain real keys.

# -- Quick-test path: personal OpenAI key (use with --openai-direct) --
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: model id. Default is gpt-4o-mini (cheap, capable enough
# for this task). Change to gpt-4o if you want stronger prose.
# OPENAI_MODEL=gpt-4o-mini

# Optional: proxy / custom endpoint. Leave unset for api.openai.com.
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# -- Production path: Azure OpenAI (default — used without --openai-direct) --
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-10-21

# -- SMTP (only needed with --send) --
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=you@example.com
# SMTP_PASSWORD=app-password-here
# SMTP_PORT=587
# BRIEFINGS_FROM_ADDRESS=you@example.com
